{
  "name": "@potionify/gameplay-tags",
  "version": "0.1.0-beta.0",
  "description": "Unreal Engine-style gameplay tags for TypeScript and JavaScript applications.",
  "license": "MIT",
  "author": "Potionify",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Potionify/gameplay-tags.git",
    "directory": "packages/gameplay-tags"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --sourcemap",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
